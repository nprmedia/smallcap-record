# Copy this file to .env and fill in keys. .env is gitignored — never commit it.

# Sharadar via Nasdaq Data Link — needed from August when the subscription starts.
NASDAQ_DATA_LINK_API_KEY=

# Tiingo free tier — used by the free/testing backend for prices.
# Sign up at https://www.tiingo.com (free) and paste the token here.
TIINGO_API_KEY=

# SEC EDGAR requires a descriptive User-Agent with a contact email. No key needed.
EDGAR_USER_AGENT=smallcap-record research np.media.market@gmail.com
